{
  "expo": {
    "name": "PinSnacks",
    "slug": "pinsnacks",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "pinsnacks",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "statusBarStyle": "light"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "userInterfaceStyle": "automatic",
      "edgeToEdgeEnabled": true,
      "navigationBar": {
        "backgroundColor": "transparent",
        "visible": false
      },
      "statusBar": {
        "backgroundColor": "transparent",
        "translucent": true,
        "hidden": false
      },
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "usesCleartextTraffic": false,
      "package": "com.zigzura.pinsnacks"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-screen-orientation",
      "expo-navigation-bar",
      "expo-router",
      [
        "react-native-edge-to-edge",
        {
          "android": {
            "parentTheme": "Default",
            "enforceNavigationBarContrast": false
          }
        }
      ],
      "expo-mail-composer",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
